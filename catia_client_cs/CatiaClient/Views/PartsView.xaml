<UserControl x:Class="CatiaClient.Views.PartsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DockPanel>
        <!-- Top bar -->
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="10">
            <TextBox Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}" Width="250" Margin="0,0,10,0"/>
            <Button Content="搜索" Command="{Binding SearchCommand}"/>
            <Button Content="刷新" Command="{Binding RefreshCommand}"/>
            <Button Content="新建零件" HorizontalAlignment="Left" Margin="20,0,0,0"/>
            <Button Content="从 CATIA 上传" HorizontalAlignment="Left"/>
            <Button Content="退出" Command="{Binding LogoutCommand}" HorizontalAlignment="Right"/>
        </StackPanel>

        <!-- Parts list -->
        <ListView ItemsSource="{Binding Parts}" Margin="10" SelectionChanged="PartsList_SelectionChanged">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="零件号" DisplayMemberBinding="{Binding PartNumber}" Width="150"/>
                    <GridViewColumn Header="名称" DisplayMemberBinding="{Binding Name}" Width="200"/>
                    <GridViewColumn Header="类型" DisplayMemberBinding="{Binding Type}" Width="80"/>
                    <GridViewColumn Header="版本" DisplayMemberBinding="{Binding CurrentVersion}" Width="60"/>
                    <GridViewColumn Header="生命周期" DisplayMemberBinding="{Binding LifecycleState}" Width="80"/>
                    <GridViewColumn Header="检入/检出" DisplayMemberBinding="{Binding CheckState}" Width="80"/>
                    <GridViewColumn Header="分支" DisplayMemberBinding="{Binding BranchName}" Width="100"/>
                </GridView>
            </ListView.View>
        </ListView>

        <!-- Status -->
        <ProgressBar DockPanel.Dock="Bottom" IsIndeterminate="{Binding IsLoading}" Height="3"/>
    </DockPanel>
</UserControl>
